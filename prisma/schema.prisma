generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  phone          String?
  role           Role
  createdAt      DateTime  @default(now())
  tests          Test[]
  approvedTests  TestResult[] @relation("ApprovedBy")
  auditLogs      AuditLog[]
  notifications  Notification[]
}

enum Role {
  ADMIN
  TESTER
  TECH_MGR
  QUAL_MGR
  PENDING
  GUEST
  RESIGNED
  MANAGER
  CLIENT
}

model Equipment {
  id                 String   @id @default(uuid())
  name               String
  status             String
  lastCalibration    DateTime
  nextCalibration    DateTime
  tests              Test[]
}

model Sample {
  id           String   @id @default(uuid())
  barcode      String   @unique
  clientId     String
  clientName   String?
  phone        String?
  email        String?
  content      String?
  consultation String?
  status       SampleStatus @default(RECEIVED)
  location     String?
  testStartDate String?
  testEndDate   String?
  testLocation  String?
  testType      String?
  testAddress   String?
  reportPdfUrl  String?
  bizNo         String?
  target        String?
  testProduct   String?
  testPurpose   String?
  testMethod    String?
  extra         String?
  testerBarcode String?
  receivedAt   DateTime @default(now())
  tests        Test[]
  consultations Consultation[]
  evidences     Evidence[]
  invoice       Invoice?
}

enum SampleStatus {
  RECEIVED
  QUOTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  DISPOSED
}

model Test {
  id             String   @id @default(uuid())
  sampleId       String
  testerId       String
  equipmentId    String
  envTemp        Float?
  envHumidity    Float?
  isEnvValid     Boolean  @default(false)
  startTime      DateTime
  endTime        DateTime?
  status         TestStatus @default(PENDING)
  sample         Sample    @relation(fields: [sampleId], references: [id])
  tester         User      @relation(fields: [testerId], references: [id])
  equipment      Equipment @relation(fields: [equipmentId], references: [id])
  result         TestResult?
}

enum TestStatus {
  PENDING
  READY
  IN_PROGRESS
  REVIEW
  APPROVED
  REJECTED
}

model TestResult {
  id              String   @id @default(uuid())
  testId          String   @unique
  rawData         String
  calculatedValue Float
  uncertainty     Float
  isApproved      Boolean  @default(false)
  approvedById    String?
  approvedAt      DateTime?
  test            Test     @relation(fields: [testId], references: [id])
  approvedBy      User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
}

model AuditLog {
  id            String   @id @default(uuid())
  tableName     String
  recordId      String
  action        String
  oldValue      String?
  newValue      String?
  changedById   String
  reason        String
  timestamp     DateTime @default(now())
  changedBy     User     @relation(fields: [changedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Consultation {
  id        String   @id @default(uuid())
  sampleId  String
  authorId  String
  message   String
  history   Json?    // Array of { message, updatedAt, authorId }
  createdAt DateTime @default(now())
  sample    Sample   @relation(fields: [sampleId], references: [id])
}

model Evidence {
  id        String   @id @default(uuid())
  sampleId  String
  uploaderId String
  fileName  String
  fileType  String
  dataUrl   String   // Base64 for now
  createdAt DateTime @default(now())
  sample    Sample   @relation(fields: [sampleId], references: [id])
}

model Invoice {
  id           String        @id @default(uuid())
  invoiceNo    String        @unique  // Usually the barcode of the Sample
  sampleId     String        @unique
  date         DateTime      @default(now())
  validUntil   DateTime?
  subtotal     Float         @default(0)
  discountRate Float         @default(0)
  discountAmt  Float         @default(0)
  vat          Float         @default(0)
  total        Float         @default(0)
  status       String        @default("DRAFT") // DRAFT, SENT, PAID
  previousNos  String?
  items        InvoiceItem[]
  sample       Sample        @relation(fields: [sampleId], references: [id])
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  title     String
  unitCost  Float
  qty       Int     @default(1)
  price     Float   @default(0)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
