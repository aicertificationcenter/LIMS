generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  phone          String?
  role           Role
  createdAt      DateTime  @default(now())
  tests          Test[]
  approvedTests  TestResult[] @relation("ApprovedBy")
  auditLogs      AuditLog[]
  notifications  Notification[]
}

enum Role {
  ADMIN
  TESTER
  TECH_MGR
  QUAL_MGR
  PENDING
  GUEST
  RESIGNED
  MANAGER
  CLIENT
  FIN_MGR
}

model Equipment {
  id                 String   @id @default(uuid())
  name               String
  status             String
  lastCalibration    DateTime
  nextCalibration    DateTime
  tests              Test[]
}

model Sample {
  id           String   @id @default(uuid())
  barcode      String   @unique
  clientId     String
  clientName   String?
  phone        String?
  email        String?
  content      String?
  consultation String?
  status       SampleStatus @default(RECEIVED)
  location     String?
  testStartDate String?
  testEndDate   String?
  testLocation  String?
  testType      String?
  testAddress   String?
  reportPdfUrl  String?
  bizNo         String?
  bizLicenseUrl String?
  target        String?
  testProduct   String?
  testPurpose   String?
  testMethod    String?
  extra         String?
  testerBarcode String?
  formalBarcode String?
  gapjiApproved Boolean @default(false)
  euljiApproved Boolean @default(false)
  gapjiRejection String?
  euljiRejection String?
  receivedAt   DateTime @default(now())
  tests        Test[]
  consultations Consultation[]
  evidences     Evidence[]
  invoice       Invoice?

  // 재무/결재 관련 필드 (모두 원 단위 저장)
  estFees        Float?  @default(0) // 총 견적금액

  advAmt         Float?  @default(0) // 착수금 예상 청구액
  advDate        String?             // 착수금 예상 청구일 (YYYY-MM-DD)
  interimAmt     Float?  @default(0) // 중도금 예상 청구액
  interimDate    String?             // 중도금 예상 청구일
  finalAmt       Float?  @default(0) // 잔금 예상 청구액
  finalDate      String?             // 잔금 예상 청구일

  advPaidAmt     Float?  @default(0) // 재무관리자 확인 착수금 입금액
  advPaidDate    String?             // 재무관리자 확인 착수금 입금일
  interimPaidAmt Float?  @default(0) // 재무관리자 확인 중도금 입금액
  interimPaidDate String?            // 재무관리자 확인 중도금 입금일
  finalPaidAmt   Float?  @default(0) // 재무관리자 확인 잔금 입금액
  finalPaidDate  String?             // 재무관리자 확인 잔금 입금일

  isDepositCompleted Boolean @default(false) // 입금 완료 여부

  // 세금계산서 발행 여부 추적
  advInvoiced     Boolean @default(false)
  interimInvoiced Boolean @default(false)
  finalInvoiced   Boolean @default(false)
}

enum SampleStatus {
  RECEIVED
  QUOTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  DISPOSED
  APPROVAL_REQUESTED
  REVISING
  APPROVED
}

model Test {
  id             String   @id @default(uuid())
  sampleId       String
  testerId       String
  equipmentId    String
  envTemp        Float?
  envHumidity    Float?
  isEnvValid     Boolean  @default(false)
  startTime      DateTime
  endTime        DateTime?
  status         TestStatus @default(PENDING)
  sample         Sample    @relation(fields: [sampleId], references: [id])
  tester         User      @relation(fields: [testerId], references: [id])
  equipment      Equipment @relation(fields: [equipmentId], references: [id])
  result         TestResult?
}

enum TestStatus {
  PENDING
  READY
  IN_PROGRESS
  REVIEW
  APPROVED
  REJECTED
}

model TestResult {
  id              String   @id @default(uuid())
  testId          String   @unique
  rawData         String
  calculatedValue Float
  uncertainty     Float
  isApproved      Boolean  @default(false)
  approvedById    String?
  approvedAt      DateTime?
  test            Test     @relation(fields: [testId], references: [id])
  approvedBy      User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
}

model AuditLog {
  id            String   @id @default(uuid())
  tableName     String
  recordId      String
  action        String
  oldValue      String?
  newValue      String?
  changedById   String
  reason        String
  timestamp     DateTime @default(now())
  changedBy     User     @relation(fields: [changedById], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Consultation {
  id        String   @id @default(uuid())
  sampleId  String
  authorId  String
  message   String
  history   Json?    // Array of { message, updatedAt, authorId }
  createdAt DateTime @default(now())
  sample    Sample   @relation(fields: [sampleId], references: [id])
}

model Evidence {
  id        String   @id @default(uuid())
  sampleId  String
  uploaderId String
  fileName  String
  fileType  String
  dataUrl   String   // Base64 for now
  createdAt DateTime @default(now())
  sample    Sample   @relation(fields: [sampleId], references: [id])
}

model Invoice {
  id           String        @id @default(uuid())
  invoiceNo    String        @unique  // Usually the barcode of the Sample
  sampleId     String        @unique
  date         DateTime      @default(now())
  validUntil   DateTime?
  subtotal     Float         @default(0)
  discountRate Float         @default(0)
  discountAmt  Float         @default(0)
  discountType String        @default("PERCENT") // PERCENT or AMOUNT
  vat          Float         @default(0)
  total        Float         @default(0)
  status       String        @default("DRAFT") // DRAFT, SENT, PAID
  previousNos  String?
  items        InvoiceItem[]
  sample       Sample        @relation(fields: [sampleId], references: [id])
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId String
  title     String
  unitCost  Float
  qty       Int     @default(1)
  price     Float   @default(0)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}
